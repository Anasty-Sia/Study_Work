<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:id="@+id/activity_library">


    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/library_back"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        app:navigationIcon ="@drawable/ic_button_back_24"
        app:titleTextAppearance="@style/content"
        app:contentInsetStartWithNavigation="12dp"
        app:title="@string/library"
        app:titleTextColor="@color/black">

    </com.google.android.material.appbar.MaterialToolbar>




</LinearLayout>